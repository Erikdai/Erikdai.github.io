@inproceedings{ijcnn2025metaphor,
  abbr        = {IJCNN 2025},
  title       = {From Metaphor to Mechanism: How LLMs Decode Traditional Chinese Medicine Symbolic Language for Modern Clinical Relevance},
  author      = {Tang, Jiacheng and Wu, Nankai and Gao, Fan and Dai, Chengxiao and Zhao, Mengyao and Zhao, Xinjie},
  booktitle   = {International Joint Conference on Neural Networks (IJCNN)},
  year        = {2025},
  arxiv       = {2503.02760},
  preview     = {metaphor.png},
  abstract    = {Metaphorical expressions abundant in Traditional Chinese Medicine (TCM) are difficult to map onto the anatomy-driven concepts of Western Medicine (WM). We propose a multi-agent, chain-of-thought framework that interprets TCM metaphors and maps them to WM pathophysiology, combining domain-specialized agents (a TCM Expert and a WM Expert) with a Coordinator Agent and stepwise reasoning for transparency and conflict resolution.},
}

