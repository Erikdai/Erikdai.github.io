@inproceedings{yan2026globalhealthatlas,
  abbr        = {ICML 2026},
  title       = {From Knowledge to Inference: Scaling Laws of Specialized Reasoning on GlobalHealthAtlas},
  author      = {Yan, Zhaokun and Xu, Shan and Dong, Wuzheng and Liu, Zhaohan and Feng, Lijie and Dai, Chengxiao and Chen, Tianqi and Liu, Binfan and Ma, Yunpu and Wei, Wenting and Li, Yingting and Zhang, Yi and Wu, Tongning},
  booktitle   = {International Conference on Machine Learning (ICML)},
  year        = {2026},
  arxiv       = {2602.00491},
  preview     = {globalhealthatlas.png},
  abstract    = {GlobalHealthAtlas is a large-scale multilingual dataset (280,210 instances across 15 public-health domains and 17 languages) built with an LLM-assisted construction and quality-control pipeline. We study scaling laws of specialized public-health reasoning and propose a domain-aligned evaluator that scores outputs along six dimensions.},
  selected    = {true}
}

